# ══════════════════════════════════════════════════════════════════════════════
#  CyberInspect AI — .env for LOCAL development (no Docker)
#  Copy this file:  cp .env.example .env
#  Then edit the values marked ⚠️  REQUIRED
# ══════════════════════════════════════════════════════════════════════════════

# ─── 1. JWT SECRET  ⚠️  REQUIRED ──────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_with_python_secrets_token_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── 2. DATABASE  ✅ Works as-is if you used default PostgreSQL setup ──────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://cyberinspect:cyberinspectpassword@localhost:5432/cyberinspectdb
POSTGRES_USER=cyberinspect
POSTGRES_PASSWORD=cyberinspectpassword
POSTGRES_DB=cyberinspectdb

# ─── 3. REDIS  ✅ Works as-is after installing Redis locally ──────────────
REDIS_URL=redis://localhost:6379/0

# ─── 4. APP URLS  ✅ No change needed for local dev ──────────────────────
APP_ENV=development
APP_NAME=CyberInspect AI
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
DEBUG=true

# ─── 5. ZAP SCANNER  ✅ Optional — skip if not using ZAP locally ─────────
# ZAP needs to be running separately: https://www.zaproxy.org/download/
ZAP_API_KEY=cyberinspect-zap-key-2024
ZAP_BASE_URL=http://localhost:8080

# ─── 6. OPENAI  ✅ Optional — AI assistant works without this ─────────────
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ─── 7. GOOGLE OAUTH  ✅ Optional — email login works without this ─────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── 8. EMAIL  ✅ Optional — forgot-password works without this ───────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@cyberinspect.ai

# ─── 9. RATE LIMITING  ✅ No change needed ────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
SCAN_RATE_LIMIT_PER_HOUR=10
